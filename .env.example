# App runtime
# Supported values: local, emulator, firebase
NEXT_PUBLIC_ENDOGUIDE_STORAGE_MODE=local
NEXT_PUBLIC_ENDOGUIDE_DEMO_MODE=false
# Emulator mode forces emulator connections; this flag also supports direct Firebase service use.
NEXT_PUBLIC_FIREBASE_USE_EMULATORS=false

# Firebase client config (required only for firebase mode; these are public client identifiers, not secrets)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase emulator hosts (optional; defaults shown below)
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1
NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1
NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_PORT=9199

# Server-side AI configuration. GEMINI_API_KEY must never use a NEXT_PUBLIC_ prefix.
# Supported providers: gemini, mock, disabled. With no key, the default is disabled.
ENDOGUIDE_AI_PROVIDER=disabled
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
ENDOGUIDE_AI_MAX_OUTPUT_TOKENS=1024

# Local-only interaction metadata logging is disabled unless explicitly enabled.
# This never stores raw prompts or responses.
NEXT_PUBLIC_ENDOGUIDE_LOCAL_AI_LOGGING=false
