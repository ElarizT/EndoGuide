rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExisting() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && userId == request.auth.uid;
      allow delete: if false;
    }

    match /biologicalEntities/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /entityRelationships/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /guidelineSnippets/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /auditLogs/{documentId} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update, delete: if false;
    }

    match /{collectionId}/{documentId} {
      allow read, update, delete: if ownsExisting();
      allow create: if ownsIncoming();
    }
  }
}
