rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function ownsPath(userId) {
      return signedIn() && userId == request.auth.uid;
    }

    function isSupportedMedicalDocument() {
      return request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/png|image/jpeg|text/plain');
    }

    match /users/{userId}/{allPaths=**} {
      allow read, delete: if ownsPath(userId);
      allow create, update: if ownsPath(userId) && isSupportedMedicalDocument();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
