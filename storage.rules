rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if signedIn() && userId == request.auth.uid;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
